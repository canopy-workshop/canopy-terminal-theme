<?xml version="1.0" encoding="utf-8"?>
<!--
  Canopy Workshop — ConEmu color palette
  Derived from canopyworkshop.com dark-mode tokens (src/styles/tokens.css):
    bg #0E1812   fg #F0EADC   brand #6FA083 (oak)   accent #E5BE6E (sun)   alarm #A8442B (kiln)

  Import: ConEmu → Settings → Features → Colors → [...] → "Load from xml file" → pick this file.
  Then select "Canopy" in the Schemes dropdown and Save settings.
-->
<key name="Software">
  <key name="ConEmu">
    <key name=".Vanilla">
      <key name="Colors">
        <key name="Palette1">
          <value name="Name" type="string" data="Canopy"/>
          <value name="ExtendColors" type="hex" data="00"/>
          <value name="ExtendColorIdx" type="hex" data="0E"/>
          <value name="TextColorIdx" type="hex" data="10"/>
          <value name="BackColorIdx" type="hex" data="01"/>
          <value name="PopTextColorIdx" type="hex" data="10"/>
          <value name="PopBackColorIdx" type="hex" data="01"/>
          <!-- ColorTableNN is 0x00BBGGRR (little-endian RGB) -->
          <value name="ColorTable00" type="dword" data="0012180e"/> <!-- #0E1812 canopy night (bg / black) -->
          <value name="ColorTable01" type="dword" data="007a6b4a"/> <!-- #4A6B7A slate (blue) -->
          <value name="ColorTable02" type="dword" data="00546e3f"/> <!-- #3F6E54 oak-500 (green) -->
          <value name="ColorTable03" type="dword" data="00848e6f"/> <!-- #6F8E84 moss-teal (cyan) -->
          <value name="ColorTable04" type="dword" data="002b44a8"/> <!-- #A8442B kiln-500 (red) -->
          <value name="ColorTable05" type="dword" data="0063508c"/> <!-- #8C5063 muted rose (magenta) -->
          <value name="ColorTable06" type="dword" data="002c8ab5"/> <!-- #B58A2C sun-600 (yellow) -->
          <value name="ColorTable07" type="dword" data="00bcccc2"/> <!-- #C2CCBC moss-300 (white) -->
          <value name="ColorTable08" type="dword" data="0029333b"/> <!-- #3B3329 loam-700 (br black) -->
          <value name="ColorTable09" type="dword" data="00a3946f"/> <!-- #6F94A3 light slate (br blue) -->
          <value name="ColorTable10" type="dword" data="0083a06f"/> <!-- #6FA083 canopy brand (br green) -->
          <value name="ColorTable11" type="dword" data="009eb3a6"/> <!-- #A6B39E moss-400 (br cyan) -->
          <value name="ColorTable12" type="dword" data="00455ec2"/> <!-- #C25E45 light kiln (br red) -->
          <value name="ColorTable13" type="dword" data="008575b0"/> <!-- #B07585 light rose (br magenta) -->
          <value name="ColorTable14" type="dword" data="006ebee5"/> <!-- #E5BE6E sun-400 (br yellow / accent) -->
          <value name="ColorTable15" type="dword" data="00dceaf0"/> <!-- #F0EADC limestone fg (br white) -->
          <value name="ColorTable16" type="dword" data="0012180e"/>
          <value name="ColorTable17" type="dword" data="0012180e"/>
          <value name="ColorTable18" type="dword" data="0012180e"/>
          <value name="ColorTable19" type="dword" data="0012180e"/>
          <value name="ColorTable20" type="dword" data="0012180e"/>
          <value name="ColorTable21" type="dword" data="0012180e"/>
          <value name="ColorTable22" type="dword" data="0012180e"/>
          <value name="ColorTable23" type="dword" data="0012180e"/>
          <value name="ColorTable24" type="dword" data="0012180e"/>
          <value name="ColorTable25" type="dword" data="0012180e"/>
          <value name="ColorTable26" type="dword" data="0012180e"/>
          <value name="ColorTable27" type="dword" data="0012180e"/>
          <value name="ColorTable28" type="dword" data="0012180e"/>
          <value name="ColorTable29" type="dword" data="0012180e"/>
          <value name="ColorTable30" type="dword" data="0012180e"/>
          <value name="ColorTable31" type="dword" data="0012180e"/>
        </key>
      </key>
    </key>
  </key>
</key>
