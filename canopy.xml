<?xml version="1.0" encoding="utf-8"?>
<!--
  Canopy Workshop — ConEmu / Cmder color palette (Dark variant).

  Derived from canopyworkshop.com dark-mode tokens (src/styles/tokens.css).
  This file matches the canonical palette at /palette.json (dark scheme),
  so ConEmu/Cmder, Windows Terminal, Alacritty, and WezTerm all show the
  same colors.

  Install:
    ConEmu → Settings (Win+Alt+P) → Features → Colors → [...] →
    "Load from xml file" → pick this file → choose "Canopy" in the
    Schemes dropdown → Save settings.
-->
<key name="Software">
  <key name="ConEmu">
    <key name=".Vanilla">
      <key name="Colors">
        <key name="Palette1">
          <value name="Name" type="string" data="Canopy"/>
          <value name="ExtendColors" type="hex" data="00"/>
          <value name="ExtendColorIdx" type="hex" data="0E"/>
          <value name="TextColorIdx" type="hex" data="10"/>
          <value name="BackColorIdx" type="hex" data="01"/>
          <value name="PopTextColorIdx" type="hex" data="10"/>
          <value name="PopBackColorIdx" type="hex" data="01"/>
          <!-- ColorTableNN is 0x00BBGGRR (little-endian RGB).
               ConEmu palette order: 0=black 1=blue 2=green 3=cyan
                                     4=red   5=magenta 6=yellow 7=white
                                     8-15 are the bright variants. -->
          <value name="ColorTable00" type="dword" data="000d120a"/> <!-- #0A120D canopy night       (black)        -->
          <value name="ColorTable01" type="dword" data="00829a8a"/> <!-- #8A9A82 spanish-moss        (blue)         -->
          <value name="ColorTable02" type="dword" data="0083a06f"/> <!-- #6FA083 oak                  (green)        -->
          <value name="ColorTable03" type="dword" data="009eb3a6"/> <!-- #A6B39E moss-light           (cyan)         -->
          <value name="ColorTable04" type="dword" data="002b44a8"/> <!-- #A8442B kiln                 (red)          -->
          <value name="ColorTable05" type="dword" data="00859ba8"/> <!-- #A89B85 loam-light           (magenta)      -->
          <value name="ColorTable06" type="dword" data="006ebee5"/> <!-- #E5BE6E sun                  (yellow)       -->
          <value name="ColorTable07" type="dword" data="00dceaf0"/> <!-- #F0EADC eggshell             (white)        -->
          <value name="ColorTable08" type="dword" data="0029333b"/> <!-- #3B3329 loam-700             (br black)     -->
          <value name="ColorTable09" type="dword" data="009eb3a6"/> <!-- #A6B39E moss-light           (br blue)      -->
          <value name="ColorTable10" type="dword" data="009bb88f"/> <!-- #8FB89B oak-light            (br green)     -->
          <value name="ColorTable11" type="dword" data="00bcccc2"/> <!-- #C2CCBC moss-300             (br cyan)      -->
          <value name="ColorTable12" type="dword" data="003a58c9"/> <!-- #C9583A kiln-light           (br red)       -->
          <value name="ColorTable13" type="dword" data="00a2b8c2"/> <!-- #C2B8A2 loam-pale            (br magenta)   -->
          <value name="ColorTable14" type="dword" data="009ad6f1"/> <!-- #F1D69A sun-light            (br yellow)    -->
          <value name="ColorTable15" type="dword" data="00f1f8fb"/> <!-- #FBF8F1 limestone            (br white)     -->
          <value name="ColorTable16" type="dword" data="000d120a"/>
          <value name="ColorTable17" type="dword" data="000d120a"/>
          <value name="ColorTable18" type="dword" data="000d120a"/>
          <value name="ColorTable19" type="dword" data="000d120a"/>
          <value name="ColorTable20" type="dword" data="000d120a"/>
          <value name="ColorTable21" type="dword" data="000d120a"/>
          <value name="ColorTable22" type="dword" data="000d120a"/>
          <value name="ColorTable23" type="dword" data="000d120a"/>
          <value name="ColorTable24" type="dword" data="000d120a"/>
          <value name="ColorTable25" type="dword" data="000d120a"/>
          <value name="ColorTable26" type="dword" data="000d120a"/>
          <value name="ColorTable27" type="dword" data="000d120a"/>
          <value name="ColorTable28" type="dword" data="000d120a"/>
          <value name="ColorTable29" type="dword" data="000d120a"/>
          <value name="ColorTable30" type="dword" data="000d120a"/>
          <value name="ColorTable31" type="dword" data="000d120a"/>
        </key>
      </key>
    </key>
  </key>
</key>
